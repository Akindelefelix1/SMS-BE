generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  super_admin
  admin
  student
  lecturer
  support
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  name         String
  role         Role
  status       String
  email        String?
  passwordHash String
  lastLogin    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  student      Student?
}

model Department {
  id       String    @id @default(cuid())
  name     String    @unique
  students Student[]
  courses  Course[]
}

model Student {
  id           String         @id @default(cuid())
  studentNo    String         @unique
  name         String
  department   Department     @relation(fields: [departmentId], references: [id])
  departmentId String
  level        String
  status       String
  user         User           @relation(fields: [userId], references: [id])
  userId       String         @unique
  registrations Registration[]
  results      Result[]
  submissions  Submission[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Course {
  id           String     @id @default(cuid())
  code         String     @unique
  title        String
  units        Int
  semester     String
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
}

model Registration {
  id           String   @id @default(cuid())
  student      Student  @relation(fields: [studentId], references: [id])
  studentId    String
  studentNo    String
  regNo        String
  semester     String
  academicYear String
  courses      Json
  createdAt    DateTime @default(now())
}

model Result {
  id           String   @id @default(cuid())
  student      Student  @relation(fields: [studentId], references: [id])
  studentId    String
  academicYear String
  semester     String
  course       String
  unit         Int
  ca           Int
  exam         Int
  total        Int
  grade        String
  createdAt    DateTime @default(now())

  @@unique([studentId, academicYear, semester, course])
}

model Submission {
  id          String   @id @default(cuid())
  student     Student  @relation(fields: [studentId], references: [id])
  studentId   String
  fileName    String
  fileType    String
  fileSize    Int
  dataUrl     String
  note        String
  status      String
  submittedAt DateTime @default(now())
  reviewedAt  DateTime?
  reviewer    String?
  reviewNote  String?
}

model Task {
  id        String   @id @default(cuid())
  text      String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
}
